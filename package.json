{
  "name": "optimark",
  "version": "0.1.1",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "test": "bun test",
    "bench": "bun run \"./bench/parser.append.bench.ts\"",
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/bun": "^1.3.2",
    "@types/jsdom": "^28.0.0",
    "@types/react": "^19.2.14",
    "jsdom": "^28.1.0",
    "react": "^19.2.4",
    "tsup": "^8.5.1",
    "typescript": "^5.8.2"
  },
  "peerDependencies": {
    "react": ">=18"
  }
}
